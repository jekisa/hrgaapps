# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# Get this from Vercel Postgres, Supabase, Neon, or other PostgreSQL provider
DATABASE_URL="postgresql://user:password@host:5432/hrga_apps?sslmode=require"

NEXTAUTH_SECRET="hrga-apps-secret-key-2024-very-secure"
# For local dev use http://localhost:3000, for production set to your Vercel domain
NEXTAUTH_URL="http://localhost:3000"
